# PrimeAgent backend env. Server-only vars per PrimeAgent.md Section 11.1.bis.
# Never prefix any var here with VITE_ (that prefix is reserved for the web bundle).
# Never commit a real .env file. Placeholders only.

# ----- Backend runtime -----
PORT=3000
APP_PORT=3700
NODE_ENV=development
DATABASE_URL="postgresql://user:pass@localhost:5432/primeagent?schema=public"

# ----- Auth -----
JWT_SECRET="REPLACE_WITH_32_BYTE_BASE64"
JWT_EXPIRES_IN=7d
BACKEND_TOKEN_ENC_KEY="REPLACE_WITH_32_BYTE_BASE64"
SIWE_DOMAIN="localhost:3000"

# ----- Anthropic / LLM -----
ANTHROPIC_API_KEY="REPLACE_WITH_ANTHROPIC_KEY"

# ----- Attestor (EIP-712 signer; one signer, multiple per-chain deployments) -----
BACKEND_ATTESTOR_PRIVATE_KEY="REPLACE_WITH_HEX_PRIVATE_KEY"
BACKEND_ATTESTOR_ADDRESS_ARB_SEPOLIA="REPLACE_WITH_DEPLOYED_ADDRESS"
BACKEND_ATTESTOR_ADDRESS_RH_CHAIN="REPLACE_WITH_DEPLOYED_ADDRESS"

# ----- Robinhood OAuth (DCR preferred per RFC 7591; hardcoded fallback supported) -----
ROBINHOOD_USE_DCR=true
ROBINHOOD_CLIENT_ID=""
ROBINHOOD_CLIENT_SECRET=""

# ----- Pimlico Alto fallback for RH Chain (chain 46630). See PrimeAgent.md 7.11.bis -----
BACKEND_PIMLICO_RH_CHAIN_URL=""

# ----- Frontend public URL (CORS allowlist + MCP Origin check) -----
FRONTEND_PUBLIC_URL="http://localhost:5173"\


 # ----- Contract addresses (Sepolia) -----
  BACKEND_ATTESTOR_ADDRESS_ARB_SEPOLIA=
  BACKEND_PRICE_ORACLE_ADDRESS_ARB_SEPOLIA=
  BACKEND_FACTORY_ADDRESS_ARB_SEPOLIA=
  BACKEND_DIAMOND_ADDRESS_ARB_SEPOLIA=
  BACKEND_AGENT_REGISTRY_ADDRESS_ARB_SEPOLIA=
  BACKEND_POSITION_NFT_ADDRESS_ARB_SEPOLIA=
  BACKEND_EMERGENCY_SHUTDOWN_ADDRESS_ARB_SEPOLIA=

  # ----- RPCs -----
  ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
  RH_CHAIN_RPC=https://rpc.testnet.chain.robinhood.com

  # ----- Price oracle signers (>=3 hex private keys, CSV) -----
  BACKEND_PRICE_SIGNER_KEYS=0x...,0x...,0x...
  BACKEND_PRICE_ASSETS_ARB_SEPOLIA=0x...,0x...
  BACKEND_PRICE_BASE_USD_DEFAULT=100

  # ----- Token encryption (rotation pair) -----
  BACKEND_TOKEN_ENC_KEY_NEXT=

  # ----- Robinhood -----
  ROBINHOOD_USE_LIVE=false
  ROBINHOOD_USE_DCR=true
  ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
  ROBINHOOD_AUTHORIZE_URL=https://robinhood.com/oauth
  ROBINHOOD_TOKEN_URL=https://api.robinhood.com/oauth2/token/
  ROBINHOOD_DCR_URL=https://agent.robinhood.com/oauth/trading/register
  OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

  # ----- LLM -----
  ANTHROPIC_API_KEY=

  # ----- Demo wiring (until AgentPolicy iteration is wired in Phase 3) -----
  BACKEND_DEMO_TOKEN_ID=1
  BACKEND_DEMO_ACCOUNT_ID=demo
  BACKEND_DEMO_USER_ID=demo-user
  ATTEST_CHAIN_ID=421614
  PRICE_CHAIN_ID=421614
