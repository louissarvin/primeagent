{
  "name": "backend-starter",
  "version": "1.0.0",
  "main": "index.ts",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun --watch index.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:push": "bunx prisma db push --config prisma/prisma.config.ts && bunx prisma generate --config prisma/prisma.config.ts",
    "db:pull": "bunx prisma db pull --config prisma/prisma.config.ts",
    "db:generate": "bunx prisma generate --config prisma/prisma.config.ts",
    "db:migrate": "bunx prisma migrate dev --config prisma/prisma.config.ts",
    "db:studio": "bunx prisma studio --config prisma/prisma.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@langchain/anthropic": "1.4.0",
    "@langchain/groq": "1.2.1",
    "@langchain/core": "1.1.48",
    "@langchain/langgraph": "1.3.4",
    "@langchain/langgraph-checkpoint-postgres": "0.1.0",
    "@langchain/mcp-adapters": "1.1.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "eta": "3.4.0",
    "pdf-lib": "1.17.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5",
    "groq-sdk": "1.2.1",
    "jose": "^5.9.6",
    "langchain": "1.4.4",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "siwe": "^3.0.0",
    "viem": "^2.52.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.10.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "bun-types": "latest",
    "eslint": "^8.57.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^7.8.0",
    "typescript": "^5.7.3"
  }
}
