# PrimeAgent Stylus margin_engine init / verify environment.
# Copy to .env in the same directory and fill in values.

# Owner EOA that ran `cargo stylus deploy` for the engine.
# This EOA becomes permanent owner on the first init() call.
STYLUS_OWNER_PRIVATE_KEY=

# Arbitrum Sepolia RPC endpoint (chain 421614).
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Live deployed Stylus margin engine.
STYLUS_MARGIN_ENGINE_ADDRESS=0x43d0c3365fdf1706bd1236d14502890278bd0cd9

# Live deployed Stylus risk engine. Leave blank until
# `cargo stylus deploy --release` returns an address; the init script
# below fails fast with a helpful message when this is unset.
STYLUS_RISK_ENGINE_ADDRESS=

# Live PriceOracle and RobinhoodMcpAttestor.
PRICE_ORACLE_ADDRESS=0xb83a5ff4a33111e8b07adc843fdb2d782826dca3
ATTESTOR_ADDRESS=0x6a31469e1aef69cec8466399d94456ad4555ad41

# Mock ERC20 stock tokens from DeployMocks broadcast (chain 421614, run-latest).
TSLA_ADDRESS=0x169d83e837e4cfa40c8cef811f7f17208497bb0a
AMZN_ADDRESS=0x70a4076afe2c4e5f563e7705b85b98342b6df4dc
PLTR_ADDRESS=0x805ea98864e42949709cac66e8339caff9310ca2
NFLX_ADDRESS=0x5079fc731bb8359add8ddec5489815325e3c30c0
AMD_ADDRESS=0x75fe0897920e708dfc4a9d16a14f0cdcdbe08188

# Margin params per asset (bps, 10000 = 100%).
# Liquidation threshold MUST be strictly less than initial requirement
# (enforced by MarginEngine.set_margin_params).
# TSLA gets a wider buffer (higher realised volatility).
TSLA_INITIAL_BPS=3000
TSLA_LIQ_BPS=2500
AMZN_INITIAL_BPS=2500
AMZN_LIQ_BPS=2000
PLTR_INITIAL_BPS=2500
PLTR_LIQ_BPS=2000
NFLX_INITIAL_BPS=2500
NFLX_LIQ_BPS=2000
AMD_INITIAL_BPS=2500
AMD_LIQ_BPS=2000

# Annualised historical volatility per asset, in basis points
# (10000 = 100%). Wave 2F defaults pulled from the spec's "Past-Winner DNA"
# table: TSLA highest, AMD and PLTR mid, AMZN and NFLX lowest.
# These feed `risk_engine.setVol(address,uint256)`.
TSLA_VOL_BPS=8000
AMZN_VOL_BPS=4500
PLTR_VOL_BPS=6500
NFLX_VOL_BPS=4500
AMD_VOL_BPS=6500
